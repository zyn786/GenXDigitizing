# ==============================================
# SECURITY: Never commit .env to version control
# Copy this file to .env and fill in real values
# ==============================================

# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/genx_digitizing?sslmode=verify-full
DIRECT_URL=postgresql://user:password@localhost:5432/genx_digitizing?sslmode=verify-full

# Authentication
AUTH_SECRET=your-secret-key-min-32-chars-generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# OAuth Providers
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OTP (One-Time Password)
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60

# Cloud Storage (S3/R2)
CHAT_ATTACHMENTS_BUCKET=your-bucket-name
ORDER_IMAGES_BUCKET=your-bucket-name
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_FORCE_PATH_STYLE=true

# Public CDN base URL for static assets (videos, portfolio images)
# Format: https://<endpoint>/<bucket>  (no trailing slash)
NEXT_PUBLIC_ASSET_BASE_URL=https://s3.example.com/your-bucket-name

# End-to-End Testing
E2E_CLIENT_EMAIL=test-client@example.com
E2E_CLIENT_PASSWORD=SecureTestPassword123!
E2E_ADMIN_EMAIL=test-admin@example.com
E2E_ADMIN_PASSWORD=SecureAdminPassword123!

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=GenX Digitizing <noreply@genxdigitizing.com>
ADMIN_EMAIL=admin@genxdigitizing.com
