# ============================================================
# StitchPro — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
# Service role key — server-side only, bypasses RLS
# Found in: Supabase Dashboard → Settings → API → service_role
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Payoneer ─────────────────────────────────────────────────
# Apply at: https://www.payoneer.com/developers/
# PAYONEER_CLIENT_ID=your-payoneer-client-id
# PAYONEER_SECRET_KEY=your-payoneer-secret-key
# PAYONEER_PROGRAM_ID=your-program-id
# Webhook URL to register: https://yourdomain.com/api/webhooks/payoneer
# PAYONEER_WEBHOOK_SECRET=your-webhook-signing-secret
# Payoneer environment — use 'sandbox' for testing, 'production' for live
# PAYONEER_ENVIRONMENT=sandbox

# ── Resend (Email) ───────────────────────────────────────────
# Sign up at: https://resend.com
# Add and verify your sending domain first
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Your Brand Name
RESEND_REPLY_TO=support@yourdomain.com

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=Your App Name
NEXT_PUBLIC_APP_TAGLINE=Your Tagline

# ── Analytics ────────────────────────────────────────────────
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Cron Security ────────────────────────────────────────────
# Must match the x-cron-secret header sent by Vercel Cron
# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_CRON_SECRET_HERE

# ── Company Info (used in emails) ────────────────────────────
COMPANY_NAME=Your Company Name
COMPANY_EMAIL=support@yourdomain.com
COMPANY_WEBSITE=https://yourdomain.com

# ── Cloudinary (Image Uploads) ───────────────────────────────
# Get from: https://cloudinary.com/console → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET

# ── S3 Storage ────────────────────────────────────────────────
CHAT_ATTACHMENTS_BUCKET=YOUR_BUCKET
S3_REGION=auto
S3_ENDPOINT=https://YOUR_S3_ENDPOINT
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY
S3_FORCE_PATH_STYLE=true

# ── VAPID (Web Push) ─────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY