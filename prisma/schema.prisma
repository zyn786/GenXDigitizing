generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  DESIGNER
  CHAT_SUPPORT
  MARKETING
  CLIENT
}

enum OtpPurpose {
  LOGIN
  VERIFY_PHONE
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
  CONSUMED
}

enum VerificationTokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum WorkflowOrderStatus {
  DRAFT
  SUBMITTED
  IN_PROGRESS
  PROOF_READY
  REVISION_REQUESTED
  PAYMENT_PENDING
  APPROVED_WAITING_PAYMENT
  APPROVED
  DELIVERED
  CLOSED
  CANCELLED
}

enum OrderPaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
}

enum ProofStatus {
  NOT_UPLOADED
  UPLOADED
  INTERNAL_REVIEW
  SENT_TO_CLIENT
  CLIENT_REVIEWING
  CLIENT_APPROVED
  REVISION_REQUESTED
}

enum QuoteStatus {
  NEW
  UNDER_REVIEW
  PRICE_SENT
  CLIENT_ACCEPTED
  CLIENT_REJECTED
  CONVERTED_TO_ORDER
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CARD
  PAYPAL
  OTHER
}

enum DiscountSource {
  MARKETING_PERCENT
  REFERRAL_PERCENT
  ADMIN_MANUAL
}

enum BillingAuditEntityType {
  INVOICE
  PAYMENT
  DISCOUNT
  TAX
  RECEIPT
}

enum ChatThreadType {
  SUPPORT
  ORDER
  INVOICE
}

enum ChatParticipantRole {
  CLIENT
  STAFF
  SYSTEM
}

enum ChatMessageVisibility {
  CLIENT_VISIBLE
  INTERNAL_ONLY
}

enum ChatMessageType {
  TEXT
  FILE
  SYSTEM
}

enum PresenceStatus {
  ONLINE
  OFFLINE
  AWAY
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

enum CampaignType {
  DISCOUNT
  REFERRAL
  FOLLOW_UP
  SEASONAL
}

enum CampaignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  REJECTED
  COMPLETED
}

enum LeadSource {
  WEBSITE
  FACEBOOK
  INSTAGRAM
  GOOGLE
  REFERRAL
  WHATSAPP
  DIRECT_VISIT
  CAMPAIGN
  MANUAL
  UNKNOWN
}

enum DesignPlacement {
  LEFT_CHEST
  RIGHT_CHEST
  HAT_FRONT
  HAT_SIDE
  HAT_BACK
  LARGE_DESIGN
  JACKET_BACK
  JACKET_CHEST
  SLEEVE_LEFT
  SLEEVE_RIGHT
  FULL_BACK
  FULL_FRONT
  POCKET
  LEG
  PUFF_LEFT_CHEST
  PUFF_HAT
  PUFF_JACKET_BACK
  OTHER
}

enum ManualPaymentAccountType {
  BANK_ACCOUNT
  CASH_APP
  PAYPAL
  VENMO
  WISE
  ZELLE
  OTHER
}

enum PaymentProofStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommissionType {
  PERCENTAGE
  FLAT_RATE
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  IN_APP
  BROWSER
}

enum NotificationEventType {
  ORDER_CREATED
  PROOF_READY
  REVISION_REQUESTED
  REVISION_PENDING
  FILE_DELIVERED
  INVOICE_SENT
  PAYMENT_RECORDED
  PAYMENT_PENDING
  INVOICE_OVERDUE
  ORDER_DELAYED
  SUPPORT_THREAD_CREATED
  SUPPORT_MESSAGE_POSTED
  THREAD_ASSIGNED
  QUOTE_PRICED
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  PROOF_SENT
  REVISION_ASSIGNED
}

enum NotificationAudience {
  CLIENT
  ASSIGNED_USER
  OPS_QUEUE
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  SEEN
  FAILED
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  phone              String?   @unique
  image              String?
  passwordHash       String?
  role               Role      @default(CLIENT)
  emailVerified      DateTime?
  phoneVerified      DateTime?
  onboardingComplete Boolean   @default(false)
  isActive           Boolean   @default(true)
  auditTotpSecret    String?
  auditTotpEnabled   Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  emailVerificationSentAt  DateTime?
  passwordResetRequestedAt DateTime?

  accounts      Account[]
  sessions      Session[]
  otpCodes      OtpCode[]
  clientProfile ClientProfile?
  staffProfile  StaffProfile?

  clientOrders        WorkflowOrder[]   @relation("ClientOrders")
  assignedOrders      WorkflowOrder[]   @relation("AssignedOrders")
  cancelledOrders     WorkflowOrder[]   @relation("CancelledOrders")
  pricedQuotes        WorkflowOrder[]   @relation("PricedQuotes")
  createdInvoices     Invoice[]         @relation("CreatedInvoices")
  paymentsRecorded    Payment[]         @relation("RecordedPayments")
  billingAuditActions BillingAuditLog[] @relation("BillingAuditActor")

  createdChatThreads      ChatThread[]             @relation("CreatedChatThreads")
  assignedChatThreads     ChatThread[]             @relation("AssignedChatThreads")
  clientChatThreads       ChatThread[]             @relation("ClientChatThreads")
  chatParticipants        ChatParticipant[]        @relation("ChatParticipantUser")
  chatMessages            ChatMessage[]            @relation("ChatMessageSender")
  presence                UserPresence?
  notificationPreferences NotificationPreference[]
  notificationLogs        NotificationLog[]        @relation("NotificationRecipientLogs")

  portfolioItems   PortfolioItem[]     @relation("PortfolioCreator")
  activityLogs     ActivityLog[]       @relation("ActivityLogActor")
  createdCoupons   Coupon[]            @relation("CouponCreator")
  approvedCoupons  Coupon[]            @relation("CouponApprover")
  createdCampaigns MarketingCampaign[] @relation("CampaignCreator")
  approvedCampaigns MarketingCampaign[] @relation("CampaignApprover")

  clientPaymentProofs   PaymentProofSubmission[] @relation("ClientPaymentProofs")
  reviewedPaymentProofs PaymentProofSubmission[] @relation("ReviewedPaymentProofs")
  orderFilesUploaded    OrderFile[]              @relation("OrderFileUploader")
  designerCommissions   DesignerCommission[]     @relation("DesignerCommissions")
  proofUploads          DesignProof[]            @relation("ProofUploads")
  proofSends            DesignProof[]            @relation("ProofSends")
  requestedRevisions    OrderRevision[]          @relation("RevisionRequestedBy")
  adminCreatedRevisions OrderRevision[]          @relation("RevisionCreatedByAdmin")
  assignedRevisions     OrderRevision[]          @relation("RevisionAssignedDesigner")
}

enum RevisionStatus {
  REQUESTED_BY_CLIENT
  CREATED_BY_ADMIN
  UNDER_ADMIN_REVIEW
  ASSIGNED_TO_DESIGNER
  IN_PROGRESS
  REVISED_PROOF_UPLOADED
  SENT_TO_CLIENT
  APPROVED
  REJECTED
  CANCELLED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String                   @unique
  purpose    VerificationTokenPurpose @default(EMAIL_VERIFICATION)
  expires    DateTime
  createdAt  DateTime                 @default(now())

  @@unique([identifier, token])
  @@index([identifier, purpose])
  @@index([expires])
}

model OtpCode {
  id         String     @id @default(cuid())
  userId     String?
  phone      String
  purpose    OtpPurpose
  codeHash   String
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  status     OtpStatus  @default(PENDING)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, purpose, status])
  @@index([userId])
}

model ClientProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  companyName     String?
  whatsapp        String?
  address         String?     @db.Text
  billingNotes    String?
  leadSource      LeadSource  @default(UNKNOWN)
  freeDesignUsed  Boolean     @default(false)
  totalOrderCount Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StaffProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  displayName    String
  department     String?
  commissionType CommissionType @default(PERCENTAGE)
  commissionRate Decimal        @default(0) @db.Decimal(6, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  designerCommissions DesignerCommission[]
}

model DesignerCommission {
  id          String           @id @default(cuid())
  designerId  String
  staffProfileId String?
  orderId     String           @unique
  amount      Decimal          @db.Decimal(10, 2)
  rate        Decimal          @db.Decimal(6, 2)
  type        CommissionType
  status      CommissionStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  designer     User          @relation("DesignerCommissions", fields: [designerId], references: [id])
  staffProfile StaffProfile? @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)
  order        WorkflowOrder @relation(fields: [orderId], references: [id])

  @@index([designerId])
  @@index([status])
}

model WorkflowOrder {
  id               String              @id @default(cuid())
  orderNumber      String              @unique
  clientUserId     String
  assignedToUserId String?
  title            String
  serviceType      String
  nicheSlug        String?
  status           WorkflowOrderStatus @default(SUBMITTED)
  proofStage       String?
  dueAt            DateTime?
  deliveredAt      DateTime?
  revisionCount    Int                 @default(0)
  progressPercent  Int                 @default(0)
  notes                String?             @db.Text
  cancelledAt          DateTime?
  cancelReason         String?             @db.Text
  cancelledByUserId    String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Production fields
  leadSource           LeadSource?
  placement            DesignPlacement?
  designHeightIn       Decimal?            @db.Decimal(6, 2)
  designWidthIn        Decimal?            @db.Decimal(6, 2)
  fabricType           String?
  is3dPuffJacketBack   Boolean             @default(false)
  trims                String?
  threadBrand          String?
  colorDetails         String?             @db.Text
  colorQuantity        Int?
  fileFormats          String[]
  stitchCount          Int?
  specialInstructions  String?             @db.Text
  isFreeDesign         Boolean             @default(false)
  estimatedPrice       Decimal?            @db.Decimal(12, 2)
  quantity             Int                 @default(1)

  // Proof workflow
  proofFileUrl         String?
  proofFileName        String?
  proofUploadedById    String?
  proofUploadedAt      DateTime?
  proofSentById        String?
  proofSentAt          DateTime?
  proofApprovedByClientAt DateTime?
  clientProofApprovedAt DateTime?
  clientProofApprovedById String?
  proofStatus          ProofStatus?

  // Quote-specific fields (populated when status = DRAFT)
  quoteStatus          QuoteStatus?
  quotedAmount         Decimal?            @db.Decimal(12, 2)
  approvedQuoteAmount  Decimal?            @db.Decimal(12, 2)
  quoteCurrency        String?             @default("USD")
  pricedByUserId       String?
  pricedAt             DateTime?
  clientRespondedAt    DateTime?
  internalNotes        String?             @db.Text
  clientMessage        String?             @db.Text
  quoteRejectionReason String?             @db.Text
  paymentRequired      Boolean             @default(false)
  paymentStatus        OrderPaymentStatus  @default(NOT_REQUIRED)

  clientUser            User                   @relation("ClientOrders", fields: [clientUserId], references: [id], onDelete: Cascade)
  assignedTo            User?                  @relation("AssignedOrders", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  cancelledBy           User?                  @relation("CancelledOrders", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  pricedBy              User?                  @relation("PricedQuotes", fields: [pricedByUserId], references: [id], onDelete: SetNull)
  invoice               Invoice?
  chatThread            ChatThread?
  notificationLogs      NotificationLog[]
  notificationOverrides NotificationOverride[]
  orderFiles            OrderFile[]
  designProofs          DesignProof[]
  revisions             OrderRevision[]
  designerCommission    DesignerCommission?

  @@index([clientUserId])
  @@index([assignedToUserId])
  @@index([cancelledByUserId])
  @@index([pricedByUserId])
  @@index([status])
  @@index([quoteStatus])
  @@index([proofUploadedById])
  @@index([proofSentById])
  @@index([clientProofApprovedById])
  @@index([paymentStatus])
}

model OrderRevision {
  id                   String         @id @default(cuid())
  orderId              String
  clientId             String
  requestedById        String?
  createdByAdminId     String?
  assignedDesignerId   String?
  revisionNumber       Int            @default(1)
  revisionInstructions String         @db.Text
  attachmentUrls       String[]
  status               RevisionStatus @default(REQUESTED_BY_CLIENT)
  adminNotes           String?        @db.Text
  designerNotes        String?        @db.Text
  requestedAt          DateTime       @default(now())
  assignedAt           DateTime?
  completedAt          DateTime?
  approvedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  order            WorkflowOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  client           User?         @relation("RevisionRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  createdByAdmin   User?         @relation("RevisionCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  assignedDesigner User?         @relation("RevisionAssignedDesigner", fields: [assignedDesignerId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([clientId])
  @@index([requestedById])
  @@index([createdByAdminId])
  @@index([assignedDesignerId])
  @@index([status])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  orderId         String        @unique
  createdByUserId String?
  clientEmail     String
  backupEmail     String?
  clientName      String
  currency        String
  dueDate         DateTime
  status          InvoiceStatus @default(DRAFT)
  subtotalAmount  Decimal       @default(0) @db.Decimal(12, 2)
  taxLabel        String?
  taxPercent      Decimal?      @db.Decimal(5, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue      Decimal       @default(0) @db.Decimal(12, 2)
  sentAt          DateTime?
  cancelledAt     DateTime?
  closedAt        DateTime?
  notes           String?       @db.Text
  filesUnlocked   Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order                 WorkflowOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy             User?                  @relation("CreatedInvoices", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lineItems             InvoiceLineItem[]
  discountLines         InvoiceDiscount[]
  payments              Payment[]
  proofSubmissions      PaymentProofSubmission[]
  auditLogs             BillingAuditLog[]
  chatThread            ChatThread?
  notificationLogs      NotificationLog[]
  notificationOverrides NotificationOverride[]

  @@index([orderId])
  @@index([createdByUserId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  label       String
  description String?  @db.Text
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal  @default(0) @db.Decimal(12, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([position])
}

model InvoiceDiscount {
  id            String         @id @default(cuid())
  invoiceId     String
  label         String
  source        DiscountSource
  percentage    Decimal        @db.Decimal(5, 2)
  appliedAmount Decimal        @default(0) @db.Decimal(12, 2)
  approvalNote  String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([source])
}

model Payment {
  id               String        @id @default(cuid())
  invoiceId        String
  recordedByUserId String?
  receiptNumber    String        @unique
  amount           Decimal       @db.Decimal(12, 2)
  currency         String
  method           PaymentMethod
  reference        String?
  clientEmail      String
  backupEmail      String?
  receiptSentAt    DateTime?
  receivedAt       DateTime
  note             String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  invoice    Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User?             @relation("RecordedPayments", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  auditLogs  BillingAuditLog[]

  @@index([invoiceId])
  @@index([recordedByUserId])
  @@index([receivedAt])
}

model BillingAuditLog {
  id            String                 @id @default(cuid())
  invoiceId     String?
  paymentId     String?
  entityType    BillingAuditEntityType
  entityId      String
  actorUserId   String?
  actorEmail    String?
  actorRole     Role?
  action        String
  reason        String?
  beforeJson    Json?
  afterJson     Json?
  keyUnlockUsed Boolean                @default(false)
  createdAt     DateTime               @default(now())

  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  actorUser User?    @relation("BillingAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([paymentId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ChatThread {
  id               String         @id @default(cuid())
  type             ChatThreadType
  subject          String
  queueKey         String?
  clientUserId     String?
  orderId          String?        @unique
  invoiceId        String?        @unique
  createdByUserId  String?
  assignedToUserId String?
  isOpen           Boolean        @default(true)
  lastMessageAt    DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  clientUser User?          @relation("ClientChatThreads", fields: [clientUserId], references: [id], onDelete: SetNull)
  createdBy  User?          @relation("CreatedChatThreads", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedTo User?          @relation("AssignedChatThreads", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  order      WorkflowOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  invoice    Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  participants     ChatParticipant[]
  messages         ChatMessage[]
  notificationLogs NotificationLog[]
  overrides        NotificationOverride[]

  @@index([type])
  @@index([clientUserId])
  @@index([assignedToUserId])
  @@index([queueKey])
  @@index([lastMessageAt])
}

model ChatParticipant {
  id          String              @id @default(cuid())
  threadId    String
  userId      String
  role        ChatParticipantRole
  lastReadAt  DateTime?
  lastSeenAt  DateTime?
  unreadCount Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  thread   ChatThread           @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User                 @relation("ChatParticipantUser", fields: [userId], references: [id], onDelete: Cascade)
  receipts ChatMessageReceipt[]

  @@unique([threadId, userId])
  @@index([userId])
  @@index([threadId])
}

model ChatMessage {
  id                  String                @id @default(cuid())
  threadId            String
  senderUserId        String?
  visibility          ChatMessageVisibility @default(CLIENT_VISIBLE)
  type                ChatMessageType       @default(TEXT)
  body                String?               @db.Text
  replyToMessageId    String?
  editedAt            DateTime?
  editCount           Int                   @default(0)
  clientEditableUntil DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  thread      ChatThread           @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender      User?                @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  replyTo     ChatMessage?         @relation("ChatReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies     ChatMessage[]        @relation("ChatReplies")
  attachments ChatAttachment[]
  receipts    ChatMessageReceipt[]

  @@index([threadId, createdAt])
  @@index([senderUserId])
  @@index([replyToMessageId])
}

model ChatAttachment {
  id        String   @id @default(cuid())
  messageId String
  bucket    String
  objectKey String   @unique
  fileName  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ChatMessageReceipt {
  id            String    @id @default(cuid())
  messageId     String
  participantId String
  deliveredAt   DateTime?
  seenAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  message     ChatMessage     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  participant ChatParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([messageId, participantId])
  @@index([participantId])
}

model UserPresence {
  userId          String         @id
  status          PresenceStatus @default(OFFLINE)
  activeThreadId  String?
  typingThreadId  String?
  isTyping        Boolean        @default(false)
  lastSeenAt      DateTime       @default(now())
  lastHeartbeatAt DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([activeThreadId])
  @@index([typingThreadId])
}

model NotificationRule {
  id              String                @id @default(cuid())
  eventType       NotificationEventType
  audience        NotificationAudience
  channel         NotificationChannel
  isEnabled       Boolean               @default(true)
  isTransactional Boolean               @default(true)
  delayMinutes    Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([eventType, audience, channel])
}

model NotificationOverride {
  id           String                @id @default(cuid())
  threadId     String?
  orderId      String?
  invoiceId    String?
  eventType    NotificationEventType
  audience     NotificationAudience
  channel      NotificationChannel
  isEnabled    Boolean               @default(true)
  delayMinutes Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  thread  ChatThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  order   WorkflowOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  invoice Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([orderId])
  @@index([invoiceId])
  @@index([eventType, audience, channel])
}

model NotificationPreference {
  id        String                @id @default(cuid())
  userId    String
  eventType NotificationEventType
  channel   NotificationChannel
  isEnabled Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType, channel])
  @@index([userId])
}

model NotificationLog {
  id                String                     @id @default(cuid())
  eventType         NotificationEventType
  audience          NotificationAudience
  channel           NotificationChannel
  status            NotificationDeliveryStatus @default(PENDING)
  threadId          String?
  orderId           String?
  invoiceId         String?
  recipientUserId   String?
  recipientAddress  String?
  queueKey          String?
  providerMessageId String?
  errorMessage      String?
  scheduledFor      DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  seenAt            DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  thread        ChatThread?    @relation(fields: [threadId], references: [id], onDelete: SetNull)
  order         WorkflowOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  invoice       Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  recipientUser User?          @relation("NotificationRecipientLogs", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([orderId])
  @@index([invoiceId])
  @@index([recipientUserId])
  @@index([queueKey])
  @@index([status, scheduledFor])
}

// ─── Pricing ──────────────────────────────────────────────────────────────────

model ServiceCategory {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  emoji       String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tiers ServiceTier[]

  @@index([isActive, sortOrder])
}

model ServiceTier {
  id         String  @id @default(cuid())
  categoryId String
  key        String
  label      String
  basePrice  Decimal @db.Decimal(10, 2)
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, key])
  @@index([categoryId, isActive])
}

model ServiceAddon {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  price     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryOption {
  id         String   @id @default(cuid())
  key        String   @unique
  label      String
  subLabel   String?
  extraPrice Decimal  @db.Decimal(10, 2) @default(0)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Portfolio ────────────────────────────────────────────────────────────────

model PortfolioItem {
  id             String   @id @default(cuid())
  title          String
  serviceKey     String
  nicheSlug      String?
  description    String?  @db.Text
  beforeImageKey String?
  afterImageKey  String?
  tags           String[]
  isFeatured     Boolean  @default(false)
  isVisible      Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdByUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy User? @relation("PortfolioCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([serviceKey, isVisible])
  @@index([isVisible, sortOrder])
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  actorRole   Role?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actorUser User? @relation("ActivityLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

// ─── Coupons & Campaigns ──────────────────────────────────────────────────────

model Coupon {
  id               String             @id @default(cuid())
  code             String             @unique
  discountType     CouponDiscountType
  discountValue    Decimal            @db.Decimal(10, 2)
  maxUses          Int?
  usedCount        Int                @default(0)
  expiresAt        DateTime?
  isActive         Boolean            @default(false)
  description      String?            @db.Text
  approvedAt       DateTime?
  approvedByUserId String?
  createdByUserId  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  createdBy  User? @relation("CouponCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy User? @relation("CouponApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([createdByUserId])
}

model MarketingCampaign {
  id               String             @id @default(cuid())
  title            String
  description      String?            @db.Text
  type             CampaignType
  status           CampaignStatus     @default(DRAFT)
  targetAudience   String?
  discountValue    Decimal?           @db.Decimal(10, 2)
  discountType     CouponDiscountType?
  startDate        DateTime?
  endDate          DateTime?
  notes            String?            @db.Text
  rejectionReason  String?            @db.Text
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  createdBy  User? @relation("CampaignCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy User? @relation("CampaignApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdByUserId])
}

// ─── Manual Payment Accounts ──────────────────────────────────────────────────

model ManualPaymentAccount {
  id           String                   @id @default(cuid())
  type         ManualPaymentAccountType
  displayName  String
  accountName  String
  accountId    String
  instructions String?                  @db.Text
  paymentLink  String?                  @db.Text
  currency     String                   @default("USD")
  isActive     Boolean                  @default(true)
  notes        String?                  @db.Text
  sortOrder    Int                      @default(0)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  proofSubmissions PaymentProofSubmission[]

  @@index([isActive, sortOrder])
}

// ─── Order Files (designer uploads, locked until payment approved) ─────────────

model OrderFile {
  id               String   @id @default(cuid())
  orderId          String
  uploadedByUserId String?
  fileName         String
  objectKey        String   @unique
  bucket           String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order      WorkflowOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy User?         @relation("OrderFileUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([uploadedByUserId])
}

// ─── Design Proofs ────────────────────────────────────────────────────────────

model DesignProof {
  id                 String    @id @default(cuid())
  orderId            String
  versionNumber      Int       @default(1)
  fileName           String
  objectKey          String    @unique
  bucket             String
  mimeType           String
  sizeBytes          Int
  uploadedByUserId   String?
  uploadedAt         DateTime  @default(now())
  sentByUserId       String?
  sentAt             DateTime?
  approvedByClientAt DateTime?
  revisionNote       String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  order      WorkflowOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy User?         @relation("ProofUploads", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  sentBy     User?         @relation("ProofSends", fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([uploadedByUserId])
  @@index([sentByUserId])
}

// ─── Pricing Config (admin-controlled key-value settings) ────────────────────

model PricingConfig {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  label           String?
  description     String?  @db.Text
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BulkDiscountRule {
  id              String   @id @default(cuid())
  minQty          Int
  discountPercent Decimal  @db.Decimal(5, 2)
  label           String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, minQty])
}

// ─── Payment Proof Submissions ────────────────────────────────────────────────

model PaymentProofSubmission {
  id               String             @id @default(cuid())
  invoiceId        String
  clientUserId     String
  paymentAccountId String?
  status           PaymentProofStatus @default(PENDING)
  proofImageKey    String
  proofImageBucket String
  amountClaimed    Decimal            @db.Decimal(12, 2)
  clientNotes      String?            @db.Text
  rejectionReason  String?            @db.Text
  reviewedByUserId String?
  reviewedAt       DateTime?
  submittedAt      DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  invoice        Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientUser     User                  @relation("ClientPaymentProofs", fields: [clientUserId], references: [id], onDelete: Cascade)
  paymentAccount ManualPaymentAccount? @relation(fields: [paymentAccountId], references: [id], onDelete: SetNull)
  reviewedBy     User?                 @relation("ReviewedPaymentProofs", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([clientUserId])
  @@index([status])
  @@index([paymentAccountId])
  @@index([reviewedByUserId])
}
