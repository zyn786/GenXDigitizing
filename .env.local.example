# ============================================================
# Copy this entire block into your .env.local file
# Replace the placeholder values with your real ones
# ============================================================

# Supabase — get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://abcdefghijklmn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App URL (for email redirects — use localhost for dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — add later
# PAYONEER_CLIENT_ID=
# PAYONEER_SECRET_KEY=
# PAYONEER_PROGRAM_ID=
# PAYONEER_WEBHOOK_SECRET=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
