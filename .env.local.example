# ============================================================
# ENVIRONMENT VARIABLES — Copy to .env.local for local dev
# Add these in Vercel Dashboard > Settings > Environment Variables
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://abcdefghijklmn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── S3 / Sharktech Storage ────────────────────────────────────
S3_REGION=auto
S3_ENDPOINT=https://s3.lax.sharktech.net
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
CHAT_ATTACHMENTS_BUCKET=genxdigitizing

# ── Cloudinary (image uploads) ─────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=GenX Digitizing <support@genxdigitizing.com>

# ── Payoneer (optional) ───────────────────────────────────────
# PAYONEER_CLIENT_ID=
# PAYONEER_SECRET_KEY=
# PAYONEER_PROGRAM_ID=
# PAYONEER_WEBHOOK_SECRET=

# ── Web Push Notifications ───────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
