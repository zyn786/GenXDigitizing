# ============================================================
# StitchPro — Environment Variables
# Copy this to .env.local and fill in your real values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://dtrkqzlwihwfzeptytvi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Payoneer — no API integration needed ──────────────────────
# Generate payment request links from your Payoneer dashboard:
# payoneer.com → Billing Service → Request a Payment
# Paste the generated links into the admin invoice panel
PAYONEER_ACCOUNT_EMAIL=your_payoneer_email@example.com
# Optional: set a webhook secret to verify payment confirmations
# PAYONEER_WEBHOOK_SECRET=your_webhook_secret_here

# ── Resend (transactional email) ─────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_FROM_NAME=StitchPro
RESEND_REPLY_TO=support@yourdomain.com

# ── Company info (used in PDF invoices + emails) ──────────────
COMPANY_NAME=StitchPro
COMPANY_EMAIL=hello@stitchpro.io
COMPANY_WEBSITE=stitchpro.io

# ── Cloudinary (portfolio image uploads) ───────────────────
# Get from: https://cloudinary.com/console → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
