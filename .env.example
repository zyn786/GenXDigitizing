# ── Payoneer ─────────────────────────────────────────────────
# Apply at: https://www.payoneer.com/developers/
# PAYONEER_CLIENT_ID=your-payoneer-client-id
# PAYONEER_SECRET_KEY=your-payoneer-secret-key
# PAYONEER_PROGRAM_ID=your-program-id
# Webhook URL to register: https://yourdomain.com/api/webhooks/payoneer
# PAYONEER_WEBHOOK_SECRET=your-webhook-signing-secret
# Payoneer environment — use 'sandbox' for testing, 'production' for live
# PAYONEER_ENVIRONMENT=sandbox

